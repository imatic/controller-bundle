{
    "name": "imatic/controller-bundle",
    "type": "symfony-bundle",
    "description": "Bundle to write simple controllers",
    "keywords": ["controller", "symfony"],
    "homepage": "https://www.imatic.cz",
    "license": "MIT",
    "authors": [
        {
            "name": "Stepan Koci",
            "email": "stepan.koci@imatic.cz"
        },
        {
            "name": "Imatic Software s.r.o.",
            "homepage": "https://www.imatic.cz"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-iconv": "*",
        "imatic/data-bundle": "dev-symfony-8.1",
        "symfony/form": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/mime": "^8.1",
        "symfony/translation": "^8.1",
        "symfony/twig-bundle": "^8.1"
    },
    "require-dev": {
        "ext-json": "*",
        "doctrine/doctrine-fixtures-bundle": "^4.0",
        "doctrine/orm": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.75",
        "imatic/testing": "^7.0",
        "symfony/browser-kit": "^8.1",
        "symfony/css-selector": "^8.1",
        "symfony/security-bundle": "^8.1",
        "symfony/validator": "^8.1",
        "symfony/web-profiler-bundle": "^8.1",
        "symfony/yaml": "^8.1"
    },
    "suggest": {
        "imatic/importexport-bundle": "Allows to use import and export apis"
    },
    "autoload": {
        "psr-4": {
            "Imatic\\Bundle\\ControllerBundle\\": ""
        },
        "exclude-from-classmap": [
            "Tests/"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "require": "^8.1"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
